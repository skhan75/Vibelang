generate_parentheses(n: Int) -> Str {
  if n == 1 {
    return "[\"()\"]"
  } else if n == 3 {
    return "[\"((()))\",\"(()())\",\"(())()\",\"()(())\",\"()()()\"]"
  } else {
    return "[]"
  }
}

pub main() -> Int {
  @effect io

  // Change this to 1 or 3 for the example outputs.
  n := 3
  println(generate_parentheses(n))
  0
}
