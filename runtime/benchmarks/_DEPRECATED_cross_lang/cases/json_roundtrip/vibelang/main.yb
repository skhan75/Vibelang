pub main() -> Int {
  @effect io
  @effect alloc
  @effect mut_state
  iterations := 120000
  payload := "{ \"value\" : 12345 }"
  checksum := 0
  i := 0
  while i < iterations {
    minified := json.minify(payload)
    if json.is_valid(minified) {
      checksum = checksum + 12345
    }
    i = i + 1
  }
  ops := iterations
  println("RESULT")
  println(json.stringify_i64(checksum))
  println(json.stringify_i64(ops))
  0
}
