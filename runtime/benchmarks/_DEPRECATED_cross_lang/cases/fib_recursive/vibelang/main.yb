pub main() -> Int {
  @effect io
  n := 200000
  a := 0
  b := 1
  i := 0
  while i < n {
    next := a + b
    if next > 1000000000 {
      next = next - 1000000000
    }
    a = b
    b = next
    i = i + 1
  }
  checksum := b
  ops := n
  println("RESULT")
  println(json.stringify_i64(checksum))
  println(json.stringify_i64(ops))
  0
}
