pub top_k_desc(xs: List<Int>, k: Int) -> List<Int> {
  @intent "return k largest values in descending order"
  @examples {
    top_k_desc([8, 1, 4], 2) => [8, 4]
    top_k_desc([], 3) => []
  }
  @require k >= 0
  @ensure len(.) <= len(xs)
  @effect alloc
  xs.sort_desc().take(k)
}

pub main() -> Int {
  @effect io
  @effect alloc
  result := top_k_desc([5, 2, 9, 1], 3)
  if len(result) == 3 {
    println("public-api-contract-ok")
  } else {
    println("public-api-contract-bad")
  }
  0
}
