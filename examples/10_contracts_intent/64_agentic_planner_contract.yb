choose_next_action(risk: Int, budget: Int) -> Int {
  @intent "allow action only when risk is within budget"
  @examples {
    choose_next_action(2, 4) => 1
    choose_next_action(5, 3) => 0
  }
  @require budget >= 0
  @ensure . >= 0
  @ensure . <= 1
  if risk <= budget {
    return 1
  }
  0
}

pub main() -> Int {
  @effect io
  result := choose_next_action(3, 3)
  if result == 1 {
    println("agentic-planner-ok")
  } else {
    println("agentic-planner-bad")
  }
  0
}
