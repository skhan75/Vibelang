pub main() -> Int {
  @effect io
  @effect net
  println(http.status_text(200))
  println(json.stringify_i64(http.default_port("https")))
  println(http.build_request_line("GET", "/health"))

  resp := http.get("http://127.0.0.1:1/unreachable", 5)
  println(resp.body)
  println(json.stringify_i64(resp.status))
  0
}
