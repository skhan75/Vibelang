add(a: Int, b: Int) -> Int {
  @examples {
    add(1, 2) => 3
    add(0, 0) => 0
  }
  a + b
}

worker(x: Int) -> Int {
  @examples {
    worker(3) => 3
    worker(0) => 0
  }
  x
}

pub main() -> Int {
  @effect io
  @effect concurrency
  task := async add(1, 2)
  value := await task
  thread worker(value)
  if value == 3 {
    println("async-thread-ok")
  } else {
    println("async-thread-bad")
  }
  0
}
