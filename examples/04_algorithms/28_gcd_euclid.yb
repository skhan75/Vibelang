gcd(a: Int, b: Int) -> Int {
  @examples {
    gcd(84, 18) => 6
    gcd(12, 8) => 4
    gcd(7, 1) => 1
    gcd(0, 5) => 5
  }
  x := a
  y := b
  while y != 0 {
    q := x / y
    r := x - (q * y)
    x = y
    y = r
  }
  x
}

pub main() -> Int {
  @effect io
  value := gcd(84, 18)
  if value == 6 {
    println("gcd-ok")
  } else {
    println("gcd-bad")
  }
  0
}
