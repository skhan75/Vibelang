factorial(n: Int) -> Int {
  @examples {
    factorial(0) => 1
    factorial(1) => 1
    factorial(5) => 120
    factorial(6) => 720
  }
  if n <= 1 {
    return 1
  }
  n * factorial(n - 1)
}

pub main() -> Int {
  @effect io
  if factorial(6) == 720 {
    println("factorial-ok")
  } else {
    println("factorial-bad")
  }
  0
}
