pub main() -> Int {
  @effect io
  @effect alloc
  @effect mut_state
  points := {"alice": 10, "bob": 7}
  points.set("alice", 12)
  points.set("carol", 9)
  if points.get("alice") == 12 {
    if points.get("carol") == 9 {
      println("map-str-int-ok")
    } else {
      println("map-str-int-bad-carol")
    }
  } else {
    println("map-str-int-bad-alice")
  }
  0
}
