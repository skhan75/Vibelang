tree_depth(node: Int, left: List<Int>, right: List<Int>) -> Int {
  if node < 0 {
    return 0
  }
  left_depth := tree_depth(left.get(node), left, right)
  right_depth := tree_depth(right.get(node), left, right)
  max(left_depth, right_depth) + 1
}

pub main() -> Int {
  @effect io
  @effect alloc
  left := [1, 3, -1, -1, -1]
  right := [2, 4, -1, -1, -1]
  depth := tree_depth(0, left, right)
  if depth == 3 {
    println("tree-depth-ok")
  } else {
    println("tree-depth-bad")
  }
  0
}
