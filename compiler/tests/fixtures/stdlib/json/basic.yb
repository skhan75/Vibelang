type User {
  id: Int,
  name: Str,
  active: Bool
}

pub main() -> Int {
  @effect io
  @effect alloc
  println(json.stringify_i64(json.parse_i64("123")))
  println(json.minify("{ \"x\" : 1 }"))
  println(json.parse("{ \"x\" : 1 }"))
  println(json.stringify("x"))
  fallback := User { id: 1, name: "fallback", active: false }
  decoded := json.decode_User("{\"id\":3,\"name\":\"neo\",\"active\":true}", fallback)
  println(json.encode_User(decoded))
  if json.is_valid("{\"x\":1}") {
    println("valid")
  }
  0
}
