notify(value: Int) -> Int {
  @effect io
  if value == 42 {
    println("select-recv")
  } else {
    println("select-other")
  }
  0
}

worker(dummy: Int) -> Int {
  @effect io
  println("go-worker")
  dummy
}

pub main() -> Int {
  @effect concurrency
  @effect io
  @effect alloc
  @effect nondet

  go worker(1)

  ch := chan(2)
  ch.send(42)

  select {
    case value := ch.recv() => notify(value)
    case after 1 => notify(0)
  }

  0
}
