notify(value: Int) -> Int {
  @effect io
  if value == 42 {
    println("select-recv")
  } else {
    println("select-other")
  }
  0
}

worker(signal) -> Int {
  @effect concurrency
  signal.send(1)
  0
}

reportGo(done: Int) -> Int {
  @effect io
  if done == 1 {
    println("go-worker")
  } else {
    println("go-other")
  }
  0
}

pub main() -> Int {
  @effect concurrency
  @effect io
  @effect alloc
  @effect nondet

  signal := chan(1)
  go worker(signal)

  select {
    case done := signal.recv() => reportGo(done)
    case after 50 => println("go-timeout")
  }

  ch := chan(2)
  ch.send(42)

  select {
    case value := ch.recv() => notify(value)
    case after 1 => notify(0)
  }

  0
}
