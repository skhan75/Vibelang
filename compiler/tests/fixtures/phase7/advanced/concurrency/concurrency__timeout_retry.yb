pub main() -> Int {
  @effect concurrency
  @effect io
  @effect alloc
  @effect nondet
  signal := chan(1)
  select {
    case value := signal.recv() => println("retry-data")
    case after 1 => println("retry-attempt-1")
  }
  signal.send(1)
  select {
    case value := signal.recv() => println("retry-ok")
    case after 1 => println("retry-failed")
  }
  0
}
