pub main() -> Int {
  @effect alloc
  @effect io
  @effect mut_state
  i := 0
  checksum := 0
  checkpoints := []

  while i < 1500 {
    xs := []
    xs.append(i)
    xs.append(i + 1)
    checksum = checksum + i + (i + 1) + xs.len()
    checkpoints.append(checksum)
    i = i + 1
  }

  if checkpoints.len() == 1500 {
    println("container-mem-ok")
    return 0
  } else {
    println("container-mem-fail")
    return 1
  }
}
