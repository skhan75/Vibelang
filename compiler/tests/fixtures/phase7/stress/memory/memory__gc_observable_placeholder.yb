gcObservablePlaceholder() -> Int {
  @effect alloc
  @effect concurrency
  ch := chan(1)
  ch.send(4)
  ch.recv()
}

pub main() -> Int {
  @effect io
  @effect alloc
  @effect concurrency
  observed := gcObservablePlaceholder()
  if observed == 4 {
    println("gc-observe-placeholder")
  } else {
    println("gc-observe-placeholder")
  }
  0
}
