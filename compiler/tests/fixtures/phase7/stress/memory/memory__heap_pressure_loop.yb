heapPressure(iter: Int) -> Int {
  @effect alloc
  i := 0
  total := 0
  while i < iter {
    total = total + i
    i = i + 1
  }
  total
}

pub main() -> Int {
  @effect io
  @effect alloc
  total := heapPressure(2000)
  if total == 1999000 {
    println("heap-ok")
  } else {
    println("heap-bad")
  }
  0
}
