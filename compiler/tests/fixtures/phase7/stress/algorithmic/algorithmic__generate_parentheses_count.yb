catalan_count(n: Int) -> Int {
  @effect alloc
  @effect mut_state
  if n <= 1 {
    return 1
  }

  total := 0
  i := 0
  while i < n {
    left := catalan_count(i)
    right := catalan_count(n - 1 - i)
    total = total + left * right
    i = i + 1
  }
  return total
}

pub main() -> Int {
  @effect io
  @effect alloc
  @effect mut_state
  target := 4
  value := catalan_count(target)
  if value == 14 {
    println("paren-ok")
    return 0
  } else {
    println("paren-fail")
    return 1
  }
}
