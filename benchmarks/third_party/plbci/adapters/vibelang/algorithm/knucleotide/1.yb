read_input_path() -> Str {
  @effect io
  raw := fs.read_text(".benchmark_input")
  if raw == "" {
    return "25000_in"
  }
  return raw
}

base_index(ch: Str) -> Int {
  if ch == "A" {
    return 0
  }
  if ch == "a" {
    return 0
  }
  if ch == "C" {
    return 1
  }
  if ch == "c" {
    return 1
  }
  if ch == "G" {
    return 2
  }
  if ch == "g" {
    return 2
  }
  if ch == "T" {
    return 3
  }
  if ch == "t" {
    return 3
  }
  return -1
}

mono_key(idx: Int) -> Str {
  if idx == 0 {
    return "A"
  }
  if idx == 1 {
    return "C"
  }
  if idx == 2 {
    return "G"
  }
  return "T"
}

di_key(idx: Int) -> Str {
  if idx == 0 { return "AA" }
  if idx == 1 { return "AC" }
  if idx == 2 { return "AG" }
  if idx == 3 { return "AT" }
  if idx == 4 { return "CA" }
  if idx == 5 { return "CC" }
  if idx == 6 { return "CG" }
  if idx == 7 { return "CT" }
  if idx == 8 { return "GA" }
  if idx == 9 { return "GC" }
  if idx == 10 { return "GG" }
  if idx == 11 { return "GT" }
  if idx == 12 { return "TA" }
  if idx == 13 { return "TC" }
  if idx == 14 { return "TG" }
  return "TT"
}

map_get0(m: Map<Int, Int>, key: Int) -> Int {
  if m.contains(key) {
    return m.get(key)
  }
  return 0
}

map_inc(m: Map<Int, Int>, key: Int) -> Void {
  @effect mut_state
  if m.contains(key) {
    m.set(key, m.get(key) + 1)
  } else {
    m.set(key, 1)
  }
}

sort_by_count_desc(counts: Map<Int, Int>, size: Int) -> List<Int> {
  @effect alloc
  @effect mut_state
  order := []
  i := 0
  while i < size {
    order.append(i)
    i = i + 1
  }
  i = 0
  while i < size {
    best := i
    j := i + 1
    while j < size {
      best_idx := order.get(best)
      cur_idx := order.get(j)
      best_count := map_get0(counts, best_idx)
      cur_count := map_get0(counts, cur_idx)
      if cur_count > best_count {
        best = j
      } else {
        if cur_count == best_count {
          if cur_idx < best_idx {
            best = j
          }
        }
      }
      j = j + 1
    }
    if best != i {
      tmp := order.get(i)
      order.set(i, order.get(best))
      order.set(best, tmp)
    }
    i = i + 1
  }
  return order
}

format_pct(count: Int, total: Int) -> Str {
  scaled := (count * 100000) / total
  whole := scaled / 1000
  frac := scaled - (whole * 1000)
  frac_text := json.stringify_i64(frac)
  if frac < 10 {
    frac_text = "00" + frac_text
  } else {
    if frac < 100 {
      frac_text = "0" + frac_text
    }
  }
  return json.stringify_i64(whole) + "." + frac_text
}

count_subseq(seq: Str, pat: Str) -> Int {
  n := seq.len()
  m := pat.len()
  if n < m {
    return 0
  }
  count := 0
  i := 0
  while i <= (n - m) {
    ok := 1
    j := 0
    while j < m {
      a := base_index(seq[i + j:i + j + 1])
      b := base_index(pat[j:j + 1])
      if a != b {
        ok = 0
        j = m
      } else {
        j = j + 1
      }
    }
    if ok == 1 {
      count = count + 1
    }
    i = i + 1
  }
  return count
}

extract_three_sequence(raw: Str) -> Str {
  seq := ""
  header_count := 0
  at_line_start := 1
  in_header := 0
  capture := 0
  i := 0
  while i < raw.len() {
    ch := raw[i:i + 1]

    if at_line_start == 1 {
      if ch == ">" {
        header_count = header_count + 1
        in_header = 1
        if header_count == 3 {
          capture = 1
        } else {
          capture = 0
        }
      } else {
        in_header = 0
      }
      at_line_start = 0
    }

    if ch == "\n" {
      at_line_start = 1
    } else {
      if capture == 1 {
        if in_header == 0 {
          if ch != "\r" {
            if ch != " " {
              if ch != "\t" {
                seq = seq + ch
              }
            }
          }
        }
      }
    }
    i = i + 1
  }
  return seq
}

pub main() -> Int {
  @effect io
  @effect alloc
  @effect mut_state

  input_path := read_input_path()
  raw := fs.read_text(input_path)
  seq := extract_three_sequence(raw)
  n := seq.len()

  mono := {0: 0}
  mono.remove(0)
  di := {0: 0}
  di.remove(0)

  i := 0
  while i < n {
    a := base_index(seq[i:i + 1])
    if a >= 0 {
      map_inc(mono, a)
      if i + 1 < n {
        b := base_index(seq[i + 1:i + 2])
        if b >= 0 {
          map_inc(di, a * 4 + b)
        }
      }
    }
    i = i + 1
  }

  mono_order := sort_by_count_desc(mono, 4)
  i = 0
  while i < mono_order.len() {
    idx := mono_order.get(i)
    println(mono_key(idx) + " " + format_pct(map_get0(mono, idx), n))
    i = i + 1
  }

  println("")

  di_order := sort_by_count_desc(di, 16)
  i = 0
  while i < di_order.len() {
    idx := di_order.get(i)
    println(di_key(idx) + " " + format_pct(map_get0(di, idx), n - 1))
    i = i + 1
  }

  println("")
  println(json.stringify_i64(count_subseq(seq, "GGT")) + "\tGGT")
  println(json.stringify_i64(count_subseq(seq, "GGTA")) + "\tGGTA")
  println(json.stringify_i64(count_subseq(seq, "GGTATT")) + "\tGGTATT")
  println(json.stringify_i64(count_subseq(seq, "GGTATTTTAATT")) + "\tGGTATTTTAATT")
  println(json.stringify_i64(count_subseq(seq, "GGTATTTTAATTTATAGT")) + "\tGGTATTTTAATTTATAGT")
  return 0
}
