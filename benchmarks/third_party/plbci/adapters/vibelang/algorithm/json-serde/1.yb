pub main() -> Int {
  @effect io
  input := fs.read_text(".benchmark_input")
  file_name := "sample"
  n := 10
  if input != "" {
    i := 0
    while i < input.len() {
      if input[i:i+1] == " " {
        file_name = input[0:i]
        n_raw := input[i+1:input.len()]
        n = json.parse_i64(n_raw)
        if n <= 0 {
          n = 10
        }
        i = input.len()
      } else {
        i = i + 1
      }
    }
    if file_name == "" {
      file_name = input
    }
  }

  raw := fs.read_text(file_name + ".json")
  canon := json.canonical(raw)
  println(hash.md5_hex(canon))
  arr := json.repeat_array(canon, n)
  println(hash.md5_hex(arr))
  return 0
}
