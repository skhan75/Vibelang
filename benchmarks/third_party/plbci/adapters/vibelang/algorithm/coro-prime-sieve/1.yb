is_prime(n: Int) -> Int {
  if n < 2 {
    return 0
  }
  d := 2
  while d * d <= n {
    rem := n - (n / d) * d
    if rem == 0 {
      return 0
    }
    d = d + 1
  }
  1
}

pub main() -> Int {
  @effect io
  @effect mut_state

  count := 0
  candidate := 2
  while count < 100 {
    if is_prime(candidate) == 1 {
      println(json.stringify_i64(candidate))
      count = count + 1
    }
    candidate = candidate + 1
  }
  0
}
