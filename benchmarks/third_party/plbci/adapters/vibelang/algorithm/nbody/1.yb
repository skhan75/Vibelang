read_input_n() -> Int {
  @effect io
  raw := fs.read_text(".benchmark_input")
  if raw == "" {
    return 1000
  }
  return json.parse_i64(raw)
}

energy(x0: Float, y0: Float, z0: Float, vx0: Float, vy0: Float, vz0: Float, m0: Float,
       x1: Float, y1: Float, z1: Float, vx1: Float, vy1: Float, vz1: Float, m1: Float,
       x2: Float, y2: Float, z2: Float, vx2: Float, vy2: Float, vz2: Float, m2: Float,
       x3: Float, y3: Float, z3: Float, vx3: Float, vy3: Float, vz3: Float, m3: Float,
       x4: Float, y4: Float, z4: Float, vx4: Float, vy4: Float, vz4: Float, m4: Float) -> Float {
  e := 0.0
  e = e + 0.5 * m0 * (vx0*vx0 + vy0*vy0 + vz0*vz0)
  e = e + 0.5 * m1 * (vx1*vx1 + vy1*vy1 + vz1*vz1)
  e = e + 0.5 * m2 * (vx2*vx2 + vy2*vy2 + vz2*vz2)
  e = e + 0.5 * m3 * (vx3*vx3 + vy3*vy3 + vz3*vz3)
  e = e + 0.5 * m4 * (vx4*vx4 + vy4*vy4 + vz4*vz4)

  dx := x0 - x1
  dy := y0 - y1
  dz := z0 - z1
  e = e - m0 * m1 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x0 - x2
  dy = y0 - y2
  dz = z0 - z2
  e = e - m0 * m2 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x0 - x3
  dy = y0 - y3
  dz = z0 - z3
  e = e - m0 * m3 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x0 - x4
  dy = y0 - y4
  dz = z0 - z4
  e = e - m0 * m4 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x1 - x2
  dy = y1 - y2
  dz = z1 - z2
  e = e - m1 * m2 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x1 - x3
  dy = y1 - y3
  dz = z1 - z3
  e = e - m1 * m3 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x1 - x4
  dy = y1 - y4
  dz = z1 - z4
  e = e - m1 * m4 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x2 - x3
  dy = y2 - y3
  dz = z2 - z3
  e = e - m2 * m3 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x2 - x4
  dy = y2 - y4
  dz = z2 - z4
  e = e - m2 * m4 / math.sqrt(dx*dx + dy*dy + dz*dz)
  dx = x3 - x4
  dy = y3 - y4
  dz = z3 - z4
  e = e - m3 * m4 / math.sqrt(dx*dx + dy*dy + dz*dz)
  e
}

pub main() -> Int {
  @effect io
  @effect mut_state

  n := read_input_n()

  pi := 3.141592653589793
  solar_mass := 4.0 * pi * pi
  year := 365.24
  dt := 0.01

  x0 := 0.0
  y0 := 0.0
  z0 := 0.0
  vx0 := 0.0
  vy0 := 0.0
  vz0 := 0.0
  m0 := solar_mass

  x1 := 4.84143144246472090
  y1 := -1.16032004402742839
  z1 := -0.103622044471123109
  vx1 := 0.00166007664274403694 * year
  vy1 := 0.00769901118419740425 * year
  vz1 := -0.0000690460016972063023 * year
  m1 := 0.000954791938424326609 * solar_mass

  x2 := 8.34336671824457987
  y2 := 4.12479856412430479
  z2 := -0.403523417114321381
  vx2 := -0.00276742510726862411 * year
  vy2 := 0.00499852801234917238 * year
  vz2 := 0.0000230417297573763929 * year
  m2 := 0.000285885980666130812 * solar_mass

  x3 := 12.894369562139131
  y3 := -15.1111514016986312
  z3 := -0.223307578892655734
  vx3 := 0.00296460137564761618 * year
  vy3 := 0.00237847173959480950 * year
  vz3 := -0.0000296589568540237556 * year
  m3 := 0.0000436624404335156298 * solar_mass

  x4 := 15.3796971148509165
  y4 := -25.9193146099879641
  z4 := 0.179258772950371181
  vx4 := 0.00268067772490389322 * year
  vy4 := 0.00162824170038242295 * year
  vz4 := -0.0000951592254519715870 * year
  m4 := 0.0000515138902046611451 * solar_mass

  px := vx0 * m0 + vx1 * m1 + vx2 * m2 + vx3 * m3 + vx4 * m4
  py := vy0 * m0 + vy1 * m1 + vy2 * m2 + vy3 * m3 + vy4 * m4
  pz := vz0 * m0 + vz1 * m1 + vz2 * m2 + vz3 * m3 + vz4 * m4
  vx0 = 0.0 - px / solar_mass
  vy0 = 0.0 - py / solar_mass
  vz0 = 0.0 - pz / solar_mass

  println(convert.format_f64(energy(x0,y0,z0,vx0,vy0,vz0,m0, x1,y1,z1,vx1,vy1,vz1,m1, x2,y2,z2,vx2,vy2,vz2,m2, x3,y3,z3,vx3,vy3,vz3,m3, x4,y4,z4,vx4,vy4,vz4,m4), 9))

  step := 0
  while step < n {
    dx := x0 - x1
    dy := y0 - y1
    dz := z0 - z1
    dist := math.sqrt(dx*dx + dy*dy + dz*dz)
    mag := dt / (dist * dist * dist)
    vx0 = vx0 - dx * m1 * mag
    vy0 = vy0 - dy * m1 * mag
    vz0 = vz0 - dz * m1 * mag
    vx1 = vx1 + dx * m0 * mag
    vy1 = vy1 + dy * m0 * mag
    vz1 = vz1 + dz * m0 * mag

    dx = x0 - x2
    dy = y0 - y2
    dz = z0 - z2
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx0 = vx0 - dx * m2 * mag
    vy0 = vy0 - dy * m2 * mag
    vz0 = vz0 - dz * m2 * mag
    vx2 = vx2 + dx * m0 * mag
    vy2 = vy2 + dy * m0 * mag
    vz2 = vz2 + dz * m0 * mag

    dx = x0 - x3
    dy = y0 - y3
    dz = z0 - z3
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx0 = vx0 - dx * m3 * mag
    vy0 = vy0 - dy * m3 * mag
    vz0 = vz0 - dz * m3 * mag
    vx3 = vx3 + dx * m0 * mag
    vy3 = vy3 + dy * m0 * mag
    vz3 = vz3 + dz * m0 * mag

    dx = x0 - x4
    dy = y0 - y4
    dz = z0 - z4
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx0 = vx0 - dx * m4 * mag
    vy0 = vy0 - dy * m4 * mag
    vz0 = vz0 - dz * m4 * mag
    vx4 = vx4 + dx * m0 * mag
    vy4 = vy4 + dy * m0 * mag
    vz4 = vz4 + dz * m0 * mag

    dx = x1 - x2
    dy = y1 - y2
    dz = z1 - z2
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx1 = vx1 - dx * m2 * mag
    vy1 = vy1 - dy * m2 * mag
    vz1 = vz1 - dz * m2 * mag
    vx2 = vx2 + dx * m1 * mag
    vy2 = vy2 + dy * m1 * mag
    vz2 = vz2 + dz * m1 * mag

    dx = x1 - x3
    dy = y1 - y3
    dz = z1 - z3
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx1 = vx1 - dx * m3 * mag
    vy1 = vy1 - dy * m3 * mag
    vz1 = vz1 - dz * m3 * mag
    vx3 = vx3 + dx * m1 * mag
    vy3 = vy3 + dy * m1 * mag
    vz3 = vz3 + dz * m1 * mag

    dx = x1 - x4
    dy = y1 - y4
    dz = z1 - z4
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx1 = vx1 - dx * m4 * mag
    vy1 = vy1 - dy * m4 * mag
    vz1 = vz1 - dz * m4 * mag
    vx4 = vx4 + dx * m1 * mag
    vy4 = vy4 + dy * m1 * mag
    vz4 = vz4 + dz * m1 * mag

    dx = x2 - x3
    dy = y2 - y3
    dz = z2 - z3
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx2 = vx2 - dx * m3 * mag
    vy2 = vy2 - dy * m3 * mag
    vz2 = vz2 - dz * m3 * mag
    vx3 = vx3 + dx * m2 * mag
    vy3 = vy3 + dy * m2 * mag
    vz3 = vz3 + dz * m2 * mag

    dx = x2 - x4
    dy = y2 - y4
    dz = z2 - z4
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx2 = vx2 - dx * m4 * mag
    vy2 = vy2 - dy * m4 * mag
    vz2 = vz2 - dz * m4 * mag
    vx4 = vx4 + dx * m2 * mag
    vy4 = vy4 + dy * m2 * mag
    vz4 = vz4 + dz * m2 * mag

    dx = x3 - x4
    dy = y3 - y4
    dz = z3 - z4
    dist = math.sqrt(dx*dx + dy*dy + dz*dz)
    mag = dt / (dist * dist * dist)
    vx3 = vx3 - dx * m4 * mag
    vy3 = vy3 - dy * m4 * mag
    vz3 = vz3 - dz * m4 * mag
    vx4 = vx4 + dx * m3 * mag
    vy4 = vy4 + dy * m3 * mag
    vz4 = vz4 + dz * m3 * mag

    x0 = x0 + dt * vx0
    y0 = y0 + dt * vy0
    z0 = z0 + dt * vz0
    x1 = x1 + dt * vx1
    y1 = y1 + dt * vy1
    z1 = z1 + dt * vz1
    x2 = x2 + dt * vx2
    y2 = y2 + dt * vy2
    z2 = z2 + dt * vz2
    x3 = x3 + dt * vx3
    y3 = y3 + dt * vy3
    z3 = z3 + dt * vz3
    x4 = x4 + dt * vx4
    y4 = y4 + dt * vy4
    z4 = z4 + dt * vz4

    step = step + 1
  }

  println(convert.format_f64(energy(x0,y0,z0,vx0,vy0,vz0,m0, x1,y1,z1,vx1,vy1,vz1,m1, x2,y2,z2,vx2,vy2,vz2,m2, x3,y3,z3,vx3,vy3,vz3,m3, x4,y4,z4,vx4,vy4,vz4,m4), 9))

  0
}
