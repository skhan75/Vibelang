read_input_n() -> Int {
  @effect io
  raw := fs.read_text(".benchmark_input")
  if raw == "" {
    return 9
  }
  return json.parse_i64(raw)
}

pow2(exp: Int) -> Int {
  v := 1
  i := 0
  while i < exp {
    v = v * 2
    i = i + 1
  }
  v
}

tree_hash(depth: Int) -> Int {
  if depth <= 0 {
    return 1
  }
  left := tree_hash(depth - 1)
  right := tree_hash(depth - 1)
  left + right
}

pub main() -> Int {
  @effect io

  n := read_input_n()
  min_depth := 4
  max_depth := n
  if min_depth + 2 > n {
    max_depth = min_depth + 2
  }

  stretch_depth := max_depth + 1
  stretch_hash := tree_hash(stretch_depth)
  println("stretch tree of depth " + json.stringify_i64(stretch_depth) + "\t root hash: " + json.stringify_i64(stretch_hash) + " check: true")

  long_lived_hash := tree_hash(max_depth)

  depth := min_depth
  while depth <= max_depth {
    iterations := pow2(max_depth - depth + min_depth)
    hash_sum := 0
    i := 0
    while i < iterations {
      hash_sum = hash_sum + tree_hash(depth)
      i = i + 1
    }
    println(json.stringify_i64(iterations) + "\t trees of depth " + json.stringify_i64(depth) + "\t root hash sum: " + json.stringify_i64(hash_sum))
    depth = depth + 2
  }

  println("long lived tree of depth " + json.stringify_i64(max_depth) + "\t root hash: " + json.stringify_i64(long_lived_hash) + " check: true")
  0
}
