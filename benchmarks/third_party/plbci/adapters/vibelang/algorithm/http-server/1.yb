read_n() -> Int {
  @effect io
  raw := fs.read_text(".benchmark_input")
  if raw == "" {
    return 10
  }
  n := json.parse_i64(raw)
  if n <= 0 {
    return 10
  }
  return n
}

pub main() -> Int {
  @effect io
  @effect net
  n := read_n()
  sum := bench.http_server_bench(n)
  println(json.stringify_i64(sum))
  return 0
}
