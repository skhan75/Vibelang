read_input_n() -> Int {
  @effect io
  raw := fs.read_text(".benchmark_input")
  if raw == "" {
    return 4
  }
  return json.parse_i64(raw)
}

pow2_scale(base: Int, exp: Int) -> Int {
  value := base
  i := 0
  while i < exp {
    value = value * 2
    i = i + 1
  }
  return value
}

format_width8(value: Int) -> Str {
  text := json.stringify_i64(value)
  n := text.len()
  if n == 1 {
    return "       " + text
  }
  if n == 2 {
    return "      " + text
  }
  if n == 3 {
    return "     " + text
  }
  if n == 4 {
    return "    " + text
  }
  if n == 5 {
    return "   " + text
  }
  if n == 6 {
    return "  " + text
  }
  if n == 7 {
    return " " + text
  }
  return text
}

nsieve(limit: Int) -> Int {
  @effect alloc
  @effect mut_state
  flags := []
  i := 0
  while i < limit {
    flags.append(1)
    i = i + 1
  }

  i = 2
  count := 0
  while i < limit {
    if flags.get(i) == 1 {
      count = count + 1
      j := i + i
      while j < limit {
        flags.set(j, 0)
        j = j + i
      }
    }
    i = i + 1
  }
  return count
}

pub main() -> Int {
  @effect io
  @effect alloc
  @effect mut_state

  n := read_input_n()
  i := 0
  while i < 3 {
    exp := n - i
    limit := pow2_scale(10000, exp)
    count := nsieve(limit)
    println("Primes up to " + format_width8(limit) + " " + format_width8(count))
    i = i + 1
  }
  return 0
}
