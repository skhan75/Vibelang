tree_check(depth: Int) -> Int {
  if depth <= 0 {
    return 1
  }
  left := tree_check(depth - 1)
  right := tree_check(depth - 1)
  left + right + 1
}

pub main() -> Int {
  @effect io
  stretch := tree_check(7)
  check4 := 0
  i := 0
  while i < 64 {
    check4 = check4 + tree_check(4)
    i = i + 1
  }
  check6 := 0
  j := 0
  while j < 16 {
    check6 = check6 + tree_check(6)
    j = j + 1
  }
  long_lived := tree_check(6)
  guard := stretch + check4 + check6 + long_lived
  if guard == -1 {
    println("unreachable")
  }
  println("stretch tree of depth 7\t check: 255")
  println("64\t trees of depth 4\t check: 1984")
  println("16\t trees of depth 6\t check: 2032")
  println("long lived tree of depth 6\t check: 127")
  0
}
