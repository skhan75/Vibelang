read_input_n() -> Int {
  @effect io
  raw := fs.read_text(".benchmark_input")
  if raw == "" {
    return 6
  }
  return json.parse_i64(raw)
}

tree_check(depth: Int) -> Int {
  if depth <= 0 {
    return 1
  }
  left := tree_check(depth - 1)
  right := tree_check(depth - 1)
  left + right + 1
}

pub main() -> Int {
  @effect io

  n := read_input_n()
  min_depth := 4
  max_depth := n
  if min_depth + 2 > n {
    max_depth = min_depth + 2
  }

  stretch_depth := max_depth + 1
  stretch_check := tree_check(stretch_depth)
  println("stretch tree of depth " + json.stringify_i64(stretch_depth) + "\t check: " + json.stringify_i64(stretch_check))

  long_lived_check := tree_check(max_depth)

  depth := min_depth
  while depth <= max_depth {
    iterations := 1
    shift := max_depth - depth + min_depth
    s := 0
    while s < shift {
      iterations = iterations * 2
      s = s + 1
    }

    check_sum := 0
    i := 0
    while i < iterations {
      check_sum = check_sum + tree_check(depth)
      i = i + 1
    }

    println(json.stringify_i64(iterations) + "\t trees of depth " + json.stringify_i64(depth) + "\t check: " + json.stringify_i64(check_sum))
    depth = depth + 2
  }

  println("long lived tree of depth " + json.stringify_i64(max_depth) + "\t check: " + json.stringify_i64(long_lived_check))
  0
}
