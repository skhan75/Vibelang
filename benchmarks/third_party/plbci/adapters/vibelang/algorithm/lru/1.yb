parse_two_ints(raw: Str) -> List<Int> {
  @effect alloc
  @effect mut_state
  values := []
  first_end := raw.len()
  i := 0
  found_space := 0
  while i < raw.len() {
    if found_space == 0 {
      if raw[i] == 32 {
        first_end = i
        found_space = 1
      }
    }
    i = i + 1
  }

  values.append(json.parse_i64(raw[0:first_end]))

  second_start := first_end
  done := 0
  while done == 0 {
    if second_start < raw.len() {
      if raw[second_start] == 32 {
        second_start = second_start + 1
      } else {
        done = 1
      }
    } else {
      done = 1
    }
  }

  if second_start < raw.len() {
    values.append(json.parse_i64(raw[second_start:]))
  } else {
    values.append(1000)
  }
  return values
}

mod_int(value: Int, m: Int) -> Int {
  return value - (value / m) * m
}

next_lcg(seed: Int) -> Int {
  return mod_int(seed * 1103515245 + 12345, 2147483648)
}

put_lru(cache: Map<Int, Int>, key: Int, tick: Int, size: Int,
        order: List<Int>, order_tick: List<Int>, head: Int) -> Int {
  @effect mut_state
  if cache.contains(key) {
    cache.set(key, tick)
    order.append(key)
    order_tick.append(tick)
    return head
  }
  if cache.len() == size {
    h := head
    evicted := 0
    while evicted == 0 {
      cand_key := order[h]
      cand_tick := order_tick[h]
      h = h + 1
      if cache.contains(cand_key) {
        cur := cache.get(cand_key)
        if cur == cand_tick {
          cache.remove(cand_key)
          evicted = 1
        }
      }
    }
    head = h
  }
  cache.set(key, tick)
  order.append(key)
  order_tick.append(tick)
  return head
}

get_lru(cache: Map<Int, Int>, key: Int, tick: Int,
        order: List<Int>, order_tick: List<Int>) -> Int {
  @effect mut_state
  if cache.contains(key) {
    cache.set(key, tick)
    order.append(key)
    order_tick.append(tick)
    return 1
  }
  return 0
}

pub main() -> Int {
  @effect io
  @effect alloc
  @effect mut_state

  raw := fs.read_text(".benchmark_input")
  args := parse_two_ints(raw)
  size := args.get(0)
  n := args.get(1)
  mod := size * 10

  cache := {0: 0}
  cache.remove(0)

  order := []
  order_tick := []
  head := 0

  seed0 := 0
  seed1 := 1
  tick := 0
  hit := 0
  missed := 0
  i := 0
  while i < n {
    seed0 = next_lcg(seed0)
    key0 := mod_int(seed0, mod)
    head = put_lru(cache, key0, tick, size, order, order_tick, head)
    tick = tick + 1

    seed1 = next_lcg(seed1)
    key1 := mod_int(seed1, mod)
    if get_lru(cache, key1, tick, order, order_tick) == 1 {
      hit = hit + 1
    } else {
      missed = missed + 1
    }
    tick = tick + 1
    i = i + 1
  }

  println(json.stringify_i64(hit))
  println(json.stringify_i64(missed))
  return 0
}
